<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <com.google.android.gms.maps.MapView xmlns:map="http://schemas.android.com/apk/res-auto"
        android:id="@+id/gmapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        map:mapType="normal" />

    <!-- Panel prowadzenia z lewej strony (styl Google Maps). Szerokosc i lewy margines
         ustawiane sa w kodzie, zeby panel trzymal sie widocznego obszaru takze w trybie split. -->
    <LinearLayout
        android:id="@+id/navPanel"
        android:layout_width="240dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#FF1B1B1D"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Blok manewru: strzalka + odleglosc do zakretu + instrukcja -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0B8043"
            android:padding="14dp">

            <TextView
                android:id="@+id/navArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                tools:text="→" />

            <TextView
                android:id="@+id/navDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                tools:text="300 m" />

            <TextView
                android:id="@+id/navInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="3"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                tools:text="Skręć w prawo w ul. Główną" />
        </LinearLayout>

        <!-- Blok informacji: czas przyjazdu + pozostaly dystans.
             paddingTop podniesiony, by "Przyjazd"/ETA zeszly PONIZEJ pasa natywnej
             pomaranczowej strzalki BMW (kolizja tylko z tymi wierszami; "Pozostalo" bylo juz czyste). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="14dp"
            android:paddingTop="64dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Przyjazd"
                android:textColor="#9AA0A6"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/navEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                tools:text="14:32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Pozostało"
                android:textColor="#9AA0A6"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/navRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                tools:text="12,4 km" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
